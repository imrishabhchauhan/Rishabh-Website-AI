{
  "entities": {
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for the website including colors, links, and prices.",
      "type": "object",
      "properties": {
        "accentColor": {
          "type": "string",
          "description": "The primary accent color (hex code)."
        },
        "accentGlowColor": {
          "type": "string",
          "description": "The glow effect color (hex code)."
        },
        "resumeUrl": {
          "type": "string",
          "description": "The URL for the resume download."
        },
        "servicePrices": {
          "type": "object",
          "description": "Prices for different services.",
          "properties": {
            "aiWorkflow": { "type": "string" },
            "marketing": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "status": {
          "type": "string",
          "description": "Current availability status (e.g., 'Open to Work')."
        }
      },
      "required": ["accentColor", "resumeUrl", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "A project delivered by Rishabh.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "participants": { "type": "string" },
        "featured": { "type": "boolean" },
        "order": { "type": "integer" }
      },
      "required": ["title", "category", "description", "imageUrl"]
    },
    "StorageStats": {
      "title": "Storage Stats",
      "description": "Statistics for the storage usage.",
      "type": "object",
      "properties": {
        "totalBytes": { "type": "integer", "description": "Total bytes uploaded to storage." }
      },
      "required": ["totalBytes"]
    }
  },
  "firestore": {
    "/settings/site-config": {
      "schema": "SiteSettings",
      "description": "The main configuration document for the site."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "A collection of projects delivered."
    },
    "/stats/storage": {
      "schema": "StorageStats",
      "description": "The document tracking total storage usage."
    }
  }
}
