rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: site-config
    // Fields:
    //   - accentColor: string (required, hex format)
    //   - accentGlowColor: string (optional, hex format)
    //   - resumeUrl: string (required, URL format)
    //   - servicePrices: map (optional)
    //   - status: string (required)
    //
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 100 chars)
    //   - category: string (required, max 50 chars)
    //   - description: string (required, max 1000 chars)
    //   - imageUrl: string (required, URL format)
    //   - tags: list (optional, max 10 items)
    //   - participants: string (optional)
    //   - featured: bool (optional)
    //   - order: int (optional)
    //
    // Collection: stats
    // Document ID: storage
    // Fields:
    //   - totalBytes: int (required, positive)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "imrishabh.work@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidSiteSettings(data) {
      return hasOnlyAllowedFields(['accentColor', 'accentGlowColor', 'resumeUrl', 'servicePrices', 'status']) &&
             data.accentColor is string && data.accentColor.matches("^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$") &&
             (!('accentGlowColor' in data) || (data.accentGlowColor is string && data.accentGlowColor.matches("^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"))) &&
             isValidUrl(data.resumeUrl) &&
             data.status is string && data.status.size() < 100;
    }

    function isValidProject(data) {
      return hasOnlyAllowedFields(['title', 'category', 'description', 'imageUrl', 'tags', 'participants', 'featured', 'order']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 1000 &&
             isValidUrl(data.imageUrl) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10)) &&
             (!('order' in data) || data.order is int);
    }

    function isValidStorageStats(data) {
      return hasOnlyAllowedFields(['totalBytes']) &&
             data.totalBytes is int && data.totalBytes >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /settings/site-config {
      allow read: if true; // Publicly readable
      allow create, update: if isAdmin() && isValidSiteSettings(request.resource.data);
    }

    match /projects/{projectId} {
      allow read: if true; // Publicly readable
      allow create, update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /stats/storage {
      allow read: if true;
      allow create, update: if isAdmin() && isValidStorageStats(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAuthenticated() && request.auth.uid == userId && hasOnlyAllowedFields(['role', 'email']) && request.resource.data.role == 'user';
    }
  }
}
